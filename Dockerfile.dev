# syntax=docker/dockerfile:1
#
# Development Dockerfile for jido_sandbox (Elixir 1.19.5 / OTP 28.1.1).
# Single-stage: source is mounted in so deps/builds recompile on the fly.

FROM hexpm/elixir:1.19.5-erlang-28.1.1-ubuntu-resolute-20260610

RUN apt-get update && apt-get install -y \
  git ca-certificates build-essential make curl libcap-dev inotify-tools \
  libnss3 libnspr4 libatk1.0-0t64 libatk-bridge2.0-0t64 libcups2t64 libdrm2 \
  libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 libgbm1 \
  libasound2t64 libatspi2.0-0t64 libxshmfence1 libpango-1.0-0 libcairo2 \
  libxcb1 libx11-6 libxext6 libxi6 libxrender1 libgdk-pixbuf-2.0-0 \
  libgtk-3-0t64 libdbus-1-3 libfontconfig1 libfreetype6 fonts-liberation && \
  rm -rf /var/lib/apt/lists/*

RUN useradd -m elixir

WORKDIR /app
RUN chown elixir:elixir /app

USER elixir
ENV SHELL=/bin/bash

COPY mix.exs mix.lock ./
RUN mix local.hex --force && \
  mix local.rebar --force && \
  mix deps.get

RUN mix jido_browser.install agent_browser

COPY lib/ lib/
COPY config/ config/
COPY notebooks/ notebooks/

RUN mix deps.get
RUN mix compile

CMD ["mix", "run", "--no-halt"]
