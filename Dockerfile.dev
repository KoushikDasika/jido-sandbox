# syntax=docker/dockerfile:1
#
# Development Dockerfile for jido_sandbox (Elixir 1.19.5 / OTP 28.1.1).
# Single-stage: source is mounted in so deps/builds recompile on the fly.

FROM hexpm/elixir:1.19.5-erlang-28.1.1-ubuntu-resolute-20260610

RUN apt-get update && apt-get install -y git ca-certificates build-essential make curl libcap-dev && \
  rm -rf /var/lib/apt/lists/*

RUN useradd -m elixir

WORKDIR /app
RUN chown elixir:elixir /app

USER elixir
ENV SHELL=/bin/bash

COPY mix.exs mix.lock ./
RUN mix local.hex --force && \
  mix local.rebar --force && \
  mix deps.get

RUN mix jido_browser.install agent_browser

COPY lib/ lib/
COPY config/ config/
COPY notebooks/ notebooks/

RUN mix deps.get
RUN mix compile

CMD ["mix", "run", "--no-halt"]
